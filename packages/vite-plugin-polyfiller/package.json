{
	"name": "@jsxtools/vite-plugin-polyfiller",
	"version": "0.1.0",
	"description": "Vite plugin that detects and injects polyfills for modern JavaScript features",
	"author": "Jonathan Neal <jonathantneal@hotmail.com> (https://jonneal.dev)",
	"homepage": "https://github.com/jsxtools/vite-utils/tree/main/packages/vite-plugin-polyfiller#readme",
	"license": "MIT-0",
	"type": "module",
	"exports": {
		".": "./dist/vite-plugin-polyfiller.js",
		"./types": "./dist/types/index.d.ts",
		"./types/*": "./dist/types/*.d.ts"
	},
	"main": "./dist/vite-plugin-polyfiller.js",
	"types": "./dist/vite-plugin-polyfiller.d.ts",
	"files": ["dist"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jsxtools/vite-utils.git",
		"directory": "packages/vite-plugin-polyfiller"
	},
	"bugs": "https://github.com/jsxtools/vite-utils/issues",
	"sideEffects": false,
	"keywords": ["vite", "vite-plugin", "polyfill", "ponyfill", "inject", "oxc"],
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc && node -e \"import('node:fs').then(fs=>fs.cpSync('src/types','dist/types',{recursive:true}))\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@jsxtools/explicit-resource-management": "^0.0.0",
		"urlpattern-polyfill": "^10.1.0"
	},
	"peerDependencies": {
		"vite": "^8.0.0"
	},
	"devDependencies": {
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	}
}
